# ===============================
# MOLS environment configuration (example)
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed. Docker Compose reads `.env` automatically; for
# `./mvnw spring-boot:run` export these variables in your shell first.
# ===============================

# --- JWT signing key (REQUIRED) ---
# Base64/hex string, minimum 256 bits for HS256.
# Generate one with:  openssl rand -hex 32
SECURITY_JWT_SECRET_KEY=

# Token lifetime in milliseconds (optional, default 24h)
SECURITY_JWT_EXPIRATION_MS=86400000

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/logistics_db
SPRING_DATASOURCE_USERNAME=logistics_user
SPRING_DATASOURCE_PASSWORD=change-me

# --- Bootstrap admin (optional, dev only) ---
# When enabled, creates an initial ADMIN user on startup if none exists.
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me

# --- Swagger UI / OpenAPI (optional) ---
# Development tool. Local `mvnw spring-boot:run` enables it by default;
# docker-compose disables it unless you opt in here.
SPRINGDOC_ENABLED=false

# --- Login lockout (optional, brute-force protection) ---
# Consecutive failed logins before a temporary lockout, and its duration.
SECURITY_LOCKOUT_MAX_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION_MS=900000

# --- Auth cookie (optional) ---
# Secure flag of the HttpOnly JWT cookie set on login for browser clients.
# Keep false only for plain-HTTP local development; true behind TLS.
SECURITY_JWT_COOKIE_SECURE=false

# --- Email (optional, Sprint 19) ---
# Off by default — the app boots and works normally with none of this set.
# Powers the low-stock/stale-order digest and the self-service password
# reset email. To try it locally without a real SMTP account, leave
# MOLS_MAIL_ENABLED=true and SPRING_MAIL_HOST=mailpit (the default in
# docker-compose.yml) and open http://localhost:8025 to see what was sent.
MOLS_MAIL_ENABLED=false
MOLS_MAIL_FROM=mols-noreply@example.com
# Base URL the SPA is reachable at — used to build the password-reset link.
MOLS_MAIL_APP_BASE_URL=http://localhost:8080
# Real SMTP server details (ignored entirely while MOLS_MAIL_ENABLED=false).
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false
